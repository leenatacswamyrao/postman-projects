    {
      "name": "DeleteBooking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Final feedback for your Collection Runner\r",
              "    pm.test(\"Cleanup Successful\", function () {\r",
              "        pm.response.to.have.status(201); // Restful-Booker returns 201 on Delete\r",
              "    });\r",
              "    \r",
              "    // Clear the variable so it's fresh for your next run\r",
              "    pm.environment.unset(\"bookingid\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
